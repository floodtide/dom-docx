{
  "name": "dom-docx",
  "version": "0.1.15",
  "description": "Convert semantic HTML fragments to native, editable Word documents (OOXML)",
  "license": "MIT",
  "author": "Blair Googer",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/floodtide/dom-docx.git"
  },
  "bugs": {
    "url": "https://github.com/floodtide/dom-docx/issues"
  },
  "homepage": "https://dom-docx.com",
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "html",
    "docx",
    "word",
    "ooxml",
    "converter",
    "document",
    "cheerio",
    "office"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "API.md",
    "examples"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "node": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./browser": {
      "types": "./dist/browser.d.ts",
      "import": "./dist/browser.js",
      "browser": "./dist/browser/dom-docx.browser.js",
      "default": "./dist/browser.js"
    }
  },
  "bin": {
    "dom-docx": "dist/cli.js"
  },
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.build.json && cp src/converter/computed-style-snapshot.browser.js src/converter/rasterize-export-prep.browser.js dist/converter/",
    "build:all": "npm run build && npm run build:browser",
    "prepack": "npm run build:all",
    "build:browser": "node scripts/build-browser.mjs",
    "setup": "playwright install chromium",
    "typecheck": "tsc --noEmit",
    "docs:sync": "tsx tools/docs-sync.ts",
    "score:suite": "tsx tools/validator.ts",
    "score:suite:priority": "tsx tools/validator.ts --priority",
    "score:suite:strict": "tsx tools/validator.ts --strict-visual",
    "score:benchmark": "tsx tools/benchmark-runner.ts all",
    "score:style-source": "tsx tools/style-source-benchmark.ts",
    "score:css-cascade": "tsx tools/css-cascade-runner.ts",
    "score:calibration": "tsx tools/calibration-runner.ts",
    "score:pin": "tsx tools/score-diff.ts --pin",
    "guard:inline": "tsx tools/inline-path-guard.ts",
    "guard:config": "tsx tools/config-options-test.ts",
    "guard:toc-slot": "tsx tools/toc-slot-test.ts",
    "guard:computed-parity": "tsx tools/computed-parity-guard.ts",
    "guard:browser-parity": "npm run build:browser && tsx scripts/browser-spike.ts && tsx tools/browser-build-parity.ts",
    "guard:pack-smoke": "node scripts/pack-smoke.mjs",
    "guard:page-break": "tsx tools/page-break-test.ts",
    "guard:internal-href": "tsx tools/internal-href-test.ts",
    "guard:document-canvas": "tsx tools/document-canvas-test.ts",
    "guard:image-spacing": "tsx tools/image-spacing-test.ts",
    "guard:table-width-units": "tsx tools/table-width-units-test.ts",
    "guard:vertical-text": "tsx tools/vertical-text-test.ts",
    "research:wild": "tsx tools/wild-runner.ts",
    "research:wild-corpus": "tsx tools/wild-corpus-build.ts",
    "research:label": "tsx tools/label-renders.ts",
    "research:concordance": "tsx tools/concordance.ts",
    "research:word-spotcheck": "tsx tools/word-spotcheck.ts",
    "research:multipage": "tsx tools/multipage-test.ts",
    "research:novel": "tsx tools/novel-runner.ts",
    "showcase": "tsx tools/showcase-runner.ts"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "cheerio": "^1.2.0",
    "docx": "^9.5.0",
    "fflate": "^0.8.3"
  },
  "devDependencies": {
    "@turbodocx/html-to-docx": "^1.22.0",
    "@types/node": "^22.15.0",
    "@types/pixelmatch": "^5.2.6",
    "@types/pngjs": "^6.0.5",
    "@xarsh/ooxml-validator": "^0.1.10",
    "esbuild": "^0.25.12",
    "html-to-docx": "^1.8.0",
    "pdf-to-img": "^6.2.0",
    "pdfjs-dist": "~5.6.205",
    "pixelmatch": "^7.1.0",
    "playwright": "^1.52.0",
    "pngjs": "^7.0.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  },
  "peerDependencies": {
    "playwright": ">=1.40.0"
  },
  "peerDependenciesMeta": {
    "playwright": {
      "optional": true
    }
  }
}
